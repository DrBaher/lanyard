# Copy to .env.local for local dev, and set the same vars in your host
# (e.g. Vercel → Project → Settings → Environment Variables) for production.

# --- LLM research (optional, server-side) ---
# The /api/research route returns a labelled stub until you add a key here.
# When set, it calls Claude with web search to brief you on speakers /
# companies / people you meet. The key stays server-side.
# ANTHROPIC_API_KEY=sk-ant-...
# RESEARCH_MODEL=claude-opus-4-8        # optional model override

# --- Research API abuse guard (optional) ---
# If set, the client must send this value as a header to call /api/research.
# A light guard against drive-by hits on the research endpoint. Leave unset to
# skip the check.
# NEXT_PUBLIC_GROUP_CODE=
